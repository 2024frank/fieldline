# ChirpStack the backend manages (internal addresses when run in the same compose)
CHIRPSTACK_GRPC=http://chirpstack:8080
CHIRPSTACK_REST=http://chirpstack-rest-api:8090
CHIRPSTACK_ADMIN_USER=admin
CHIRPSTACK_ADMIN_PASS=change-me

# Readings datastore (internal)
READINGS_URL=http://datastore:8000/readings

# App auth
JWT_SECRET=generate-a-long-random-string
DATA_PATH=/data/fieldline.json

# Comma-separated emails allowed to onboard organizations
PLATFORM_ADMINS=admin

# Public host gateways should point at (shown on the gateway settings card)
PUBLIC_HOST=your.server.ip

# Optional: onboarding emails via Resend (domain must be verified in Resend)
RESEND_API_KEY=
MAIL_FROM=Fieldline <fieldline@yourdomain.com>
APP_URL=https://your-app-domain
ADMIN_URL=https://your-admin-domain
